PROJECT_NAME="notioncal-to-gcal"
PROJECT_TYPE="nodejs-cjs"
MAX_CALLS_PER_HOUR=60
CLAUDE_TIMEOUT_MINUTES=10
CLAUDE_OUTPUT_FORMAT="json"

# Notion — create an internal integration at https://www.notion.so/my-integrations
# then share your database with the integration
NOTION_TOKEN=

# Notion database ID — extract from your database URL
# e.g. https://notion.so/workspace/29c7ff3886cd4fea92400f24d5618388?v=...
#                                  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_DATABASE_ID=29c7ff3886cd4fea92400f24d5618388

# Google Cloud Console — https://console.cloud.google.com/
# Create a project → Enable Google Calendar API → OAuth 2.0 credentials → Web application
# Add http://localhost:3000/auth/callback as an Authorised redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Google Calendar ID of the target calendar (not "primary")
# Find it in Google Calendar → Settings → your calendar → "Calendar ID"
GOOGLE_CALENDAR_ID=

# =============================================================================
# OPTIONAL FAN-OUT SINKS
# =============================================================================
# Everything below is OPTIONAL. If the vars for a sink are missing, that sink is
# INERT — it is silently skipped and never crashes the run. Google Calendar sync
# works with none of these set. All fan-out (Discord events + socials) only fires
# for Notion pages whose `Announce` checkbox is ticked.

# --- Discord (scheduled events + the ✅ approval channel) -----------------------
# From the Discord Developer Portal (the "MAC Projects" app):
#   Bot tab → reset & copy token; OAuth2 → URL Generator (bot scope +
#   Manage Events / Send Messages / Read Message History / Add Reactions) → invite.
# Guild/channel/user IDs: enable Developer Mode in Discord, then right-click → Copy ID.
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BOT_USER_ID=
DISCORD_CONFIRM_CHANNEL_ID=
# Fallback times (24h HH:MM, Australia/Melbourne) for all-day events, since
# Discord scheduled events require exact start/end times.
DISCORD_DEFAULT_START=18:00
DISCORD_DEFAULT_END=21:00

# --- LinkedIn (company page) — needs Community Management API approval ----------
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_ID=
# LINKEDIN_API_VERSION=202405

# --- Facebook + Instagram (Meta Graph API) — needs App Review + Business Verif. -
# Facebook + Instagram share the same Page access token.
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
IG_USER_ID=
# GRAPH_API_VERSION=v21.0

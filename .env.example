# Notion — create an internal integration at https://www.notion.so/my-integrations
# then share your database with the integration
NOTION_TOKEN=

# Notion database ID — extract from your database URL
# e.g. https://notion.so/workspace/29c7ff3886cd4fea92400f24d5618388?v=...
#                                  ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^
NOTION_DATABASE_ID=29c7ff3886cd4fea92400f24d5618388

# Google Cloud Console — https://console.cloud.google.com/
# Create a project → Enable Google Calendar API → OAuth 2.0 credentials → Web application
# Add http://localhost:3000/auth/callback as an Authorised redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Google Calendar ID of the target calendar (not "primary")
# Find it in Google Calendar → Settings → your calendar → "Calendar ID"
GOOGLE_CALENDAR_ID=
